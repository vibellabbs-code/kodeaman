{
  "name": "@kodeaman/output-html",
  "version": "0.1.0",
  "description": "Self-contained HTML evidence report generator for KodeAman OWASP security scans",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@kodeaman/schema": "workspace:*"
  },
  "devDependencies": {
    "@kodeaman/config": "workspace:*",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vibellabbs-code/kodeaman.git",
    "directory": "packages/output-html"
  },
  "homepage": "https://github.com/vibellabbs-code/kodeaman#readme",
  "bugs": {
    "url": "https://github.com/vibellabbs-code/kodeaman/issues"
  },
  "keywords": [
    "kodeaman",
    "security",
    "html",
    "reports",
    "evidence"
  ]
}
